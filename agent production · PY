def _bd(style="thin", color="CCCCCC"):
    return Side(style=style, color=color)

BT = Border(left=_bd(), right=_bd(), top=_bd(), bottom=_bd())
BM = Border(left=_bd("medium","999999"), right=_bd("medium","999999"),
            top=_bd("medium","999999"),  bottom=_bd("medium","999999"))

def fc(cell, v, bg="FFFFFF", fg="000000", bold=False, size=9,
       fmt=None, ha="center", wrap=False, italic=False):
    cell.value = v
    cell.font  = Font(color=fg, bold=bold, size=size, name="Arial", italic=italic)
    cell.fill  = PatternFill("solid", fgColor=bg)
    cell.alignment = Alignment(horizontal=ha, vertical="center", wrap_text=wrap)
    cell.border = BT
    if fmt: cell.number_format = fmt

def hdr(cell, v, bg="1A1A2E", fg="FFFFFF", size=9, bold=True):
    fc(cell, v, bg=bg, fg=fg, bold=bold, size=size)
    cell.border = BM


