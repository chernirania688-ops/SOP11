def analyse_capacity(article_id, art_dict, time_cols, context):
    """Compatibilité avec app.py — retourne un DataFrame."""
    R = compute_mrp(article_id, art_dict, time_cols, context)
    rows = []
    res = R["resource"]
    for w in time_cols:
        rows.append({
            "Période": w, "Article": article_id, "Ressource": res,
            "Besoin brut [U]": sg(find_series(art_dict,"gross","requirement"), w),
            f"Charge [{res}]": R["workload"].get(w, 0),
            f"Capacité [{res}]": sg(find_series(art_dict,"available","capacity"), w),
            "Surplus": R["surplus"].get(w, 0),
            "Safety stock [U]": sg(find_series(art_dict,"safety","stock"), w),
            "Plan prod [U]": sg(find_series(art_dict,"production","plan"), w),
            "Statut": R["status"].get(w, ""),
        })
    return pd.DataFrame(rows)


def generate_adjusted_plan(df: pd.DataFrame, art_dict: dict) -> pd.DataFrame:
    """Compatibilité avec app.py."""
    df = df.copy()
    var_s = find_series(art_dict, "variable","requirement")
    var_def = float(var_s.dropna().median()) if not var_s.empty else 0.4667
    res = df.columns[4].replace("Charge [","").replace("]","") if len(df.columns)>4 else "PHR"
    actions = []
    for _, row in df.iterrows():
        st = row.get("Statut","")
        g  = row.get("Besoin brut [U]", 0)
        c  = row.get(f"Capacité [{res}]", 0) if f"Capacité [{res}]" in row.index else 0
        if "SURCHARGE" in str(st) and c > 0 and var_def > 0:
            max_u = round(c / var_def, 0)
            actions.append({"Période": row["Période"], "Plan ajusté [U]": max_u, "Action": f"Réduit {g:.0f}→{max_u:.0f} U"})
        else:
            actions.append({"Période": row["Période"], "Plan ajusté [U]": g, "Action": "Plan maintenu"})
    return df.merge(pd.DataFrame(actions), on="Période", how="left")


def run(context: dict = None) -> dict:
    ctx = context or {}
    print("\n" + "="*60)
    print("🤖 AGENT PRODUCTION — CALCUL MRP COMPLET")
    print("="*60)

    prod_file = ctx.get("prod_file")
    if not prod_file:
        candidates = list(Path(".").glob("*.xlsx"))
        prod_file = next(
            (str(f) for f in candidates if any(k in f.name.lower() for k in ["prod","mps","exemple"]) and "output" not in f.name.lower()),
            str(candidates[0]) if candidates else None
        )
    if not prod_file or not Path(prod_file).exists():
        return {"agent":"production","status":"error","error":"Aucun fichier production trouvé"}

    print(f"  📂 Source : {Path(prod_file).name}")
    data = load_production_file(prod_file)

    mrp_results = {}
    total_surcharges, total_alertes = [], []

    for art_id, art_dict in data["articles"].items():
        print(f"\n  🏭 Article {art_id} — {len(data['time_cols'])} périodes")
        R = compute_mrp(art_id, art_dict, data["time_cols"], ctx)
        mrp_results[art_id] = R

        surcharges = [w for w,s in R["status"].items() if "SURCHARGE" in str(s)]
        alertes    = [w for w,s in R["status"].items() if "ALERTE"    in str(s)]
        total_surcharges.extend(surcharges)
        total_alertes.extend(alertes)
        print(f"    🔴 {len(surcharges)} surcharge(s) | 🟡 {len(alertes)} alerte(s)")

    output_path = ctx.get("output_path",
                          str(Path(prod_file).parent / "output_agent_production_complet.xlsx"))
    write_excel(mrp_results, output_path)

    return {
        "agent": "production", "status": "success",
        "fichier_source": Path(prod_file).name,
        "articles_analysed": len(mrp_results),
        "periodes_analysees": len(data["time_cols"]),
        "surcharges_detectees": len(total_surcharges),
        "alertes_detectees": len(total_alertes),
        "periodes_surcharge": total_surcharges,
        "periodes_alerte": total_alertes,
        "capacity_ok": len(total_surcharges) == 0,
        "output_file": output_path,
        "calculs_ajoutes": ["Charge [PHR]","Surplus [PHR]","Statut","Besoins nets [U]",
                            "Stock projeté [U]","Planned order receipts","Planned order releases","Plan ajusté"],
    }


if __name__ == "__main__":
    import argparse
    p = argparse.ArgumentParser()
    p.add_argument("--file", default=None)
    args = p.parse_args()
    result = run({"prod_file": args.file})
    for k, v in result.items():
        if k not in ("output_file","periodes_surcharge","periodes_alerte","calculs_ajoutes"):
            print(f"  {k}: {v}")
