# UTILITAIRES
# ══════════════════════════════════════════════════════════════════════════════

def cn(v) -> float:
    if v is None: return 0.0
    if isinstance(v, (int, float)):
        return float(v) if not (isinstance(v, float) and np.isnan(v)) else 0.0
    if isinstance(v, str):
        v = v.strip().replace(" ", "").replace(",", ".")
        try: return float(v)
        except: return 0.0
    return 0.0


def find_series(art_dict: dict, *keywords) -> pd.Series:
    """Trouve une série dans le dict article par mots-clés."""
    kws = [k.lower() for k in keywords]
    for key, series in art_dict.items():
        if all(kw in key.lower() for kw in kws):
            return series
    return pd.Series(dtype=float)


def sg(series, col, default=0.0) -> float:
    """safe_get : lit une valeur d'une série."""
    if isinstance(series, dict):
        return cn(series.get(col, default))
    if isinstance(series, pd.Series):
        if series.empty: return default
        try:
            v = series.get(col, default)
            return cn(v) if v is not None else default
        except: return default
    return default


# ══════════════════════════════════════════════════════════════════════════════
# CALCUL MRP COMPLET PAR ARTICLE
# ══════════════════════════════════════════════════════════════════════════════

def compute_mrp(art_id: str, art_dict: dict, time_cols: list, context: dict) -> dict:
    """
    Calcule tous les indicateurs MRP pour un article, période par période.
    Logique réelle d'un système MRP/ERP.
    """
    # Extraction données source
    gross    = find_series(art_dict, "gross", "requirement")
    var_req  = find_series(art_dict, "variable", "requirement")
    cap      = find_series(art_dict, "available", "capacity")
    init_inv = find_series(art_dict, "initial", "inventory")
    safety   = find_series(art_dict, "safety", "stock")
    batch    = find_series(art_dict, "batch", "size")
    min_plan = find_series(art_dict, "minimum", "production")
    prod_plan= find_series(art_dict, "production", "plan")
    frozen   = find_series(art_dict, "frozen")

    # Détection ressource
    resource = "PHR"
    for key in art_dict.keys():
        if "capacity" in key.lower() and "[" in key:
            resource = key.split("[")[-1].replace("]","").strip()
            break

    # Valeurs par défaut
    cap_def = float(cap.dropna().median()) if not cap.empty and len(cap.dropna())>0 else 1400.0
    var_def = float(var_req.dropna().median()) if not var_req.empty and len(var_req.dropna())>0 else 0.4667
    ss_def  = float(safety.dropna().median()) if not safety.empty and len(safety.dropna())>0 else 0.0
    bat_def = float(batch.dropna().median()) if not batch.empty and len(batch.dropna())>0 else 1.0

    # Stock initial
    inv = sg(init_inv, time_cols[0], 0.0)
    demand_boost = context.get("demand_boost", 1.0)

    # Résultats calculés
    R = {
        "resource":   resource,
        "article":    art_id,
        "time_cols":  time_cols,
        "source":     art_dict,  # conserve la source
        "workload":   {},
        "surplus":    {},
        "status":     {},
        "net_req":    {},
        "proj_inv":   {},
        "ord_receipt":{},
        "ord_release":{},
        "plan_ajuste":{},
        "action":     {},
    }

    for w in time_cols:
        g   = sg(gross,    w) * demand_boost
        v   = sg(var_req,  w) or var_def
        c   = sg(cap,      w) or cap_def
        ss  = sg(safety,   w) or ss_def
        bat = sg(batch,    w) or bat_def
        pp  = sg(prod_plan, w)
        frz = sg(frozen,   w)
        mp  = sg(min_plan, w)

        # 1. Charge [PHR]
        wl = round(g * v, 2)
        R["workload"][w] = wl

        # 2. Surplus [PHR]
        surp = round(c - wl, 2)
        R["surplus"][w] = surp

        # 3. Statut
        if c <= 0:      st = "⚪ INCONNU"
        elif surp < 0:  st = "🔴 SURCHARGE"
        elif surp < c * 0.15: st = "🟡 ALERTE"
        else:           st = "🟢 OK"
        R["status"][w] = st

        # 4. Besoins nets
        net = max(0.0, g - inv + ss)
        R["net_req"][w] = round(net, 2)

        # 5. Planned orders (arrondi au batch, minimum plan)
        if net > 0:
            po = max(bat * np.ceil(net / bat), mp)
        else:
            po = 0.0
        R["ord_receipt"][w] = round(po, 2)
        R["ord_release"][w] = round(po, 2)

        # 6. Stock projeté fin de période
        inv_end = round(inv + pp - g, 2)
        R["proj_inv"][w] = inv_end

        # 7. Plan ajusté
        if "SURCHARGE" in st and frz == 0 and v > 0:
            max_u = round(c / v, 0)
            R["plan_ajuste"][w] = max_u
            R["action"][w] = f"Réduit {g:.0f}→{max_u:.0f} U (max cap. {c:.0f} {resource})"
        elif "ALERTE" in st:
            R["plan_ajuste"][w] = pp
            R["action"][w] = "Surveillance — marge capacité < 15%"
        elif "SURCHARGE" in st and frz == 1:
            R["plan_ajuste"][w] = pp
            R["action"][w] = "Figé (frozen=1) — surcharge non corrigeable"
        else:
            R["plan_ajuste"][w] = pp
            R["action"][w] = "Plan maintenu ✓"

        inv = inv_end

    return R


